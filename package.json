{
  "name": "voxsalon",
  "version": "1.0.0",
  "description": "AI voice receptionist for Ukrainian cosmetology clinics",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "tunnel": "ngrok http 3000",
    "log:tail": "tail -f data/call_logs.jsonl | pino-pretty",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "node-telegram-bot-api": "^0.67.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "@types/node-telegram-bot-api": "^0.64.14",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}