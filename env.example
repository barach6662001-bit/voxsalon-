# ─────────────────────────────────────────────
# VoxSalon — Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ─── Anthropic (Claude Code itself uses this) ───
# Get from: https://gym-rat.online (reseller) or console.anthropic.com (official)
ANTHROPIC_API_KEY=sk-ant-zB3a42K9SzIECIULqa7aeOmDvyb1TpNTZxHhixB3x5w

# Optional: set custom base URL (e.g., gym-rat.online for reseller)
# Leave empty to use official api.anthropic.com
ANTHROPIC_BASE_URL=https://gym-rat.online

# Model for call summarization
# Use claude-haiku-4-5-20251001 for official, claude-opus-4-7 for gym-rat
ANTHROPIC_SUMMARY_MODEL=claude-haiku-4-5-20251001

# ─── Vapi — Voice AI middleware ───
# Sign up: https://dashboard.vapi.ai
# Free tier includes test minutes
VAPI_API_KEY=e7f23315-1cf6-46f9-8a37-522cf000cbef
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID=a156c286-3f74-4a8c-88b6-30e96703b352
VAPI_PHONE_NUMBER_ID=

# ─── Telegram Bot — Owner notifications ───
# 1. Open Telegram, message @BotFather
# 2. Send /newbot, follow prompts
# 3. BotFather gives you token
# 4. Get your chat ID: message @userinfobot
TELEGRAM_BOT_TOKEN=8622018433:AAF7OzwSdzicR6laigLOxttmK-P_3uLZI44
TELEGRAM_OWNER_CHAT_ID=445146020

# ─── ElevenLabs — Ukrainian TTS (configured inside Vapi) ───
# Sign up: https://elevenlabs.io
# Free tier: 10k chars/month
ELEVENLABS_API_KEY=

# ─── OpenAI — LLM brain (configured inside Vapi) ───
# Get from: https://platform.openai.com/api-keys
# Used by Vapi to generate replies; you can use Claude instead later
OPENAI_API_KEY=sk-proj-...

# ─── Server ───
PORT=3000
NODE_ENV=development

# Used to verify Vapi webhook signature
PUBLIC_BASE_URL=https://your-ngrok-or-vercel-url

# ─── Optional: when adding Altegio later ───
# ALTEGIO_BEARER_TOKEN=
# ALTEGIO_COMPANY_ID=

# ─── Optional: when adding Supabase later ───
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Optional: telephony provider if not using Vapi's numbers ───
# Twilio account (Vapi can also provision numbers automatically)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
